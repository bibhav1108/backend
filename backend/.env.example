# Database Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sahyog_setu

# Security & JWT
SECRET_KEY=replace_with_a_secure_secret_key_64_chars_at_least
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Telegram API Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# CORS Settings
ALLOWED_ORIGINS="https://sahyog-setu-frontend.vercel.app,http://localhost:3000"

# Email Settings (Brevo HTTP API)
BREVO_API_KEY=your_brevo_api_key_here
EMAILS_FROM_EMAIL=your_verified_email@gmail.com
EMAILS_FROM_NAME=SahyogSync
